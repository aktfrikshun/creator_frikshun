FLASK_APP=app.py
FLASK_ENV=development
DATABASE_URL=postgresql+psycopg://frikshun:frikshun_dev@localhost:54329/frikshun_content_development
FACEBOOK_TARGET_TYPE=page
FACEBOOK_GRAPH_VERSION=v20.0
FACEBOOK_DRY_RUN=true
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v20.0
INSTAGRAM_DRY_RUN=true
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Public HTTPS directory containing the same filenames stored in artifact media_path.
INSTAGRAM_MEDIA_BASE_URL=
THREADS_API_VERSION=v1.0
THREADS_API_BASE_URL=https://graph.threads.net
THREADS_AUTH_URL=https://threads.net/oauth/authorize
THREADS_DRY_RUN=true
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=
THREADS_TOKEN_PATH=instance/threads_oauth.json
THREADS_ACCESS_TOKEN=
THREADS_LONG_LIVED_ACCESS_TOKEN=
# Optional fallback public HTTPS directory for non-S3 media paths.
THREADS_MEDIA_BASE_URL=
S3_MEDIA_BUCKET=frikshun-social-media
S3_MEDIA_REGION=us-east-1
S3_MEDIA_PREFIX=social
S3_PRESIGN_SECONDS=3600
X_DRY_RUN=true
X_USERNAME=
X_CONSUMER_KEY=
X_SECRET_KEY=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
# Optional OAuth 2.0 credentials, not used by the OAuth 1.0a publisher.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
FANVUE_DRY_RUN=true
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_REDIRECT_URI=
FANVUE_TOKEN_PATH=instance/fanvue_oauth.json
FANVUE_AUDIENCE=followers-and-subscribers
FANVUE_ACCESS_TOKEN=
FANVUE_REFRESH_TOKEN=
FANVUE_API_VERSION=2025-06-26
MEDIA_ANALYZER_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
TIKTOK_REEL_VIDEO_PROVIDER=animatic
KLING_CLI_BIN=kling
KLING_VIDEO_MODEL=kling-video-v3_0
KLING_POLL_SECONDS=600
KLING_ENABLE_AUDIO=true
FFMPEG_BIN=ffmpeg
# Optional future manual intervention point for true motion generation:
KLING_API_KEY=
KLING_API_BASE_URL=
